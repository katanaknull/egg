-- PS99 Hybrid Optimizer (Gem + Hatch)
local Network = game:GetService("ReplicatedStorage"):WaitForChild("Network")
local Player = game.Players.LocalPlayer

_G.Active = true

-- 1. MODÜL: Işınlanma Hızında Gem/Orb Toplama
task.spawn(function()
    while _G.Active do
        local Orbs = game:GetService("Workspace").Map:FindFirstChild("Orbs")
        if Orbs then
            for _, orb in pairs(Orbs:GetChildren()) do
                -- Gem orblarını önceliklendirir ve anında karaktere çeker
                orb.CFrame = Player.Character.HumanoidRootPart.CFrame
            end
        end
        task.wait(0.01) -- Maksimum hız denetimi
    end
end)

-- 2. MODÜL: Otomatik Huge Egg Hatch (En Hızlı Mod)
-- 'EggName' kısmına görselde gördüğün güncel egg ismini yazmalısın (Örn: "Hacker Egg")
local function FastHatch(eggName, quantity)
    local args = {
        [1] = eggName,
        [2] = quantity
    }
    Network:WaitForChild("Eggs_RequestPurchase"):InvokeServer(unpack(args))
end

-- 3. MODÜL: Breakable (Elmas Yığınları) Hedefleme
task.spawn(function()
    while _G.Active do
        local ActiveCoins = game:GetService("Workspace").Map:FindFirstChild("ActiveCoins")
        if ActiveCoins then
            for _, obj in pairs(ActiveCoins:GetChildren()) do
                -- Sadece elmas içeren objelere saldırır
                if string.find(obj.Name, "Diamond") or string.find(obj.Name, "Gem") then
                    Network:WaitForChild("Breakables_PlayerClick"):InvokeServer(obj.Name)
                end
            end
        end
        task.wait(0.1)
    end
end)

print("Üst Düzey Hybrid Script Aktif: Gem Farm ve Hatch modülleri çalışıyor.")
