-- PS99 Denetim Scripti v2
local Player = game.Players.LocalPlayer
local Library = require(game:GetService("ReplicatedStorage").Library)

-- Hızlı Geliştirme Ayarları
_G.AutoCollect = true
_G.AutoEgg = false

-- 1. Otomatik Para/Ganimet Toplama Fonksiyonu
-- Bu fonksiyon, yerdeki coinlerin merkeze çekilme hızını test eder.
task.spawn(function()
    while _G.AutoCollect do
        local Orbs = game:GetService("Workspace").Map:FindFirstChild("Orbs")
        if Orbs then
            for _, orb in pairs(Orbs:GetChildren()) do
                -- Orb toplama hızını simüle eder
                orb.CFrame = Player.Character.HumanoidRootPart.CFrame
            end
        end
        task.wait(0.1) -- Sunucu yükü denetimi için bekleme süresi
    end
end)

-- 2. Otomatik Yumurta Açma Denetimi
-- Scriptin "Hızlı Karakter Gelişimi" vaadini test eder.
local function OpenEgg(eggName, amount)
    local args = {
        [1] = eggName,
        [2] = amount
    }
    -- Oyunun kendi Remote eventini tetikler
    game:GetService("ReplicatedStorage"):WaitForChild("Network"):WaitForChild("Eggs_RequestPurchase"):InvokeServer(unpack(args))
end

print("Denetim Scripti Başlatıldı: Orb toplama aktif.")
