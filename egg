-- Gem Farm Denetim Scripti
local Player = game.Players.LocalPlayer
local Network = game:GetService("ReplicatedStorage"):WaitForChild("Network")

_G.GemFarm = true

-- 1. Elmas Toplama (Magnet Denetimi)
task.spawn(function()
    while _G.GemFarm do
        local Orbs = game:GetService("Workspace").Map:FindFirstChild("Orbs")
        if Orbs then
            for _, orb in pairs(Orbs:GetChildren()) do
                -- Sadece elmas (Diamond/Gem) orblarını filtreleyebilir veya hepsini çekebilirsin
                orb.CFrame = Player.Character.HumanoidRootPart.CFrame
            end
        end
        task.wait(0.05) -- Çok hızlı toplama, sunucu korumasını test eder
    end
end)

-- 2. Alanlardaki Elmas Yığınlarına Pet Gönderme
-- Not: Bu kısım, bulunduğun alandaki elmasları hedef alır.
task.spawn(function()
    while _G.GemFarm do
        local ActiveCoins = game:GetService("Workspace").Map:FindFirstChild("ActiveCoins")
        if ActiveCoins then
            for _, coin in pairs(ActiveCoins:GetChildren()) do
                -- Eğer objenin adı "Diamond" veya "Gem" içeriyorsa petleri yönlendir
                if string.find(coin.Name, "Diamond") or string.find(coin.Name, "Gem") then
                    -- Petleri ilgili elmasa saldırtma sinyali (Remote check)
                    Network:WaitForChild("Breakables_PlayerClick"):InvokeServer(coin.Name)
                end
            end
        end
        task.wait(0.5)
    end
end)

print("Gem Farm Modülü Aktif: Elmaslar toplanıyor.")
