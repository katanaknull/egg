-- PS99 DIRECT INJECTION SCRIPT (SOLARA COMPATIBLE)
-- Arayüz yoktur, doğrudan oyunun 'Network' katmanına sinyal gönderir.

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Network = ReplicatedStorage:WaitForChild("Network")

-- TEST MODU AKTİF
_G.HizliGelisim = true

print("--- TEST BASLATILDI: PS99 NETWORK BYPASS ---")

-- 1. ELMAS VE COINLERI ANINDA TOPLA (ORB COLLECTOR)
task.spawn(function()
    while _G.HizliGelisim do
        local orbs = {}
        -- Sahadaki tüm elmas/paraları tespit et
        for _, v in pairs(game.Workspace.__THINGS.Orbs:GetChildren()) do
            table.insert(orbs, v.Name)
        end
        
        -- Bulduğun her şeyi tek bir paketle sunucuya 'Topladım' diye gönder
        if #orbs > 0 then
            Network:FindFirstChild("Orbs_Collect"):FireServer(orbs)
        end
        task.wait(0.3) -- Sunucu güvenliği için optimize edildi
    end
end)

-- 2. ALAN HASARI (HER SEYI AYNI ANDA KIRMA)
task.spawn(function()
    while _G.HizliGelisim do
        local things = game.Workspace.__THINGS.Breakables:GetChildren()
        for i = 1, #things do
            -- Videodaki mantık: Tek tek vurmak yerine her objeye sinyal yolla
            if things[i] and things[i]:FindFirstChild("Hitbox") then
                Network:FindFirstChild("Breakables_PlayerDamage"):FireServer(things[i].Name)
            end
            -- CPU kasmaması ve Solara'nın çökmemesi için küçük bir ara
            if i % 20 == 0 then task.wait() end 
        end
        task.wait(0.1)
    end
end)

-- 3. OTOMATIK HEDIYE/LOOTBAG TOPLAMA
task.spawn(function()
    while _G.HizliGelisim do
        Network:FindFirstChild("Lootbags_Claim"):FireServer({})
        task.wait(1)
    end
end)

print("--- SCRIPT ARKA PLANDA CALISIYOR ---")
print("Gelisimi gormek icin elmas miktarini kontrol et.")
