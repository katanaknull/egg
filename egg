-- Basit bir Hub Arayüz Yapısı Örneği
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "PS99 Geliştirici Denetim Paneli",
   LoadingTitle = "Sistem Kontrol Ediliyor...",
   LoadingSubtitle = "by Eren",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "PS99_Denetim",
      FileName = "Ayarlar"
   }
})

-- Ana Sekme: Otomasyon
local MainTab = Window:CreateTab("Otomasyon", 4483362458) -- İkon ID

local Section = MainTab:CreateSection("Hızlı Gelişim Modülleri")

local Toggle = MainTab:CreateToggle({
   Name = "Auto-Farm (En Yakın Hedef)",
   CurrentValue = false,
   Flag = "Toggle1", 
   Callback = function(Value)
      -- Buraya petleri en yakın coin'e gönderen fonksiyon gelecek
      _G.AutoFarm = Value
      if Value then
          print("Auto-Farm Başlatıldı: Verimlilik Modu Aktif.")
      end
   end,
})

local Slider = MainTab:CreateSlider({
   Name = "Saldırı Hızı (MS)",
   Min = 10,
   Max = 500,
   CurrentValue = 100,
   Flag = "Slider1",
   Callback = function(Value)
      -- Saldırı döngüsü arasındaki bekleme süresini ayarlar
      _G.AttackSpeed = Value
   end,
})

-- Diğer Sekme: Güvenlik Denetimi
local SafetyTab = Window:CreateTab("Güvenlik", 4483362458)

local Label = SafetyTab:CreateLabel("Anti-Cheat Risk Durumu: Düşük")

local Dropdown = SafetyTab:CreateDropdown({
   Name = "Yürüme Modu",
   Options = {"Normal","İnsan Benzeri (Safe)","Işınlanma (Riskli)"},
   CurrentOption = {"Normal"},
   MultipleOptions = false,
   Flag = "Dropdown1",
   Callback = function(Option)
      print("Seçilen Mod: " .. Option[1])
   end,
})
